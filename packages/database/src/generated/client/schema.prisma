generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  apiKey      String       @unique @default(cuid())
  users       User[]
  workflows   Workflow[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invitations Invitation[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(MEMBER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Workflow {
  id          String            @id @default(uuid())
  name        String
  description String?
  definition  Json?
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions    WorkflowVersion[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId])
}

model WorkflowVersion {
  id         String         @id @default(uuid())
  workflowId String
  workflow   Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version    Int
  status     WorkflowStatus @default(DRAFT)
  definition Json
  executions Execution[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([workflowId, version])
  @@index([workflowId])
}

model Execution {
  id                String          @id @default(uuid())
  workflowVersionId String
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id])
  status            ExecutionStatus @default(PENDING)
  steps             ExecutionStep[]
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  logs              ExecutionLog[]

  @@index([workflowVersionId])
  @@index([status])
}

model ExecutionStep {
  id          String          @id @default(uuid())
  executionId String
  execution   Execution       @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId      String
  status      ExecutionStatus @default(PENDING)
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  @@unique([executionId, nodeId])
  @@index([executionId])
}

model ProcessedEvent {
  eventId   String   @id
  topic     String
  status    String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model DeadLetterQueue {
  id         String    @id @default(uuid())
  topic      String
  payload    Json
  error      String
  failedAt   DateTime  @default(now())
  replayed   Boolean   @default(false)
  replayedAt DateTime?
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model ExecutionLog {
  id          String    @id @default(uuid())
  executionId String
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  nodeId      String
  status      String
  message     String?
  timestamp   DateTime  @default(now())

  @@index([executionId])
}
